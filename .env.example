# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ─── Model ─────────────────────────────────────────────────────────────────────
MODEL_NAME=distilbert-base-uncased-finetuned-sst-2-english
# Path to a fine-tuned checkpoint (leave blank to use the HF hub model above)
FINE_TUNED_MODEL_PATH=
MAX_SEQUENCE_LENGTH=512
INFERENCE_BATCH_SIZE=16
# Confidence threshold below which prediction is flagged as "uncertain"
CONFIDENCE_THRESHOLD=0.6

# ─── Database ──────────────────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=sentiment_user
POSTGRES_PASSWORD=sentiment_pass
POSTGRES_DB=sentiment_db
DATABASE_URL=postgresql+asyncpg://sentiment_user:sentiment_pass@db:5432/sentiment_db

# ─── Benchmarking ──────────────────────────────────────────────────────────────
LATENCY_TARGET_MS=200
BENCHMARK_SAMPLE_SIZE=500
BENCHMARK_RESULTS_DIR=/app/benchmark_results
